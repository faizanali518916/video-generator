{
	"name": "video-generator",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "concurrently -k \"vite --host 0.0.0.0\" \"tsx watch server/index.ts\"",
		"build": "tsc --noEmit && vite build",
		"start": "tsx server/index.ts",
		"format": "prettier --write .",
		"studio": "remotion studio src/remotion/index.ts",
		"test": "vitest run --config vitest.config.ts",
		"lint": "tsc --noEmit"
	},
	"dependencies": {
		"@remotion/bundler": "4.0.484",
		"@remotion/captions": "4.0.484",
		"@remotion/cli": "4.0.484",
		"@remotion/install-whisper-cpp": "4.0.484",
		"@remotion/player": "4.0.484",
		"@remotion/renderer": "4.0.484",
		"express": "^5.1.0",
		"multer": "^2.0.1",
		"react": "19.2.3",
		"react-dom": "19.2.3",
		"react-router-dom": "^7.6.3",
		"remotion": "4.0.484",
		"zod": "^3.25.67"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.1.11",
		"@types/express": "^5.0.3",
		"@types/multer": "^1.4.12",
		"@types/node": "^22.15.34",
		"@types/react": "19.2.7",
		"@types/react-dom": "19.2.3",
		"@types/supertest": "^6.0.3",
		"@vitejs/plugin-react": "^4.6.0",
		"concurrently": "^9.2.0",
		"prettier": "^3.9.4",
		"supertest": "^7.1.1",
		"tailwindcss": "^4.1.11",
		"tsx": "^4.20.3",
		"typescript": "^5.9.3",
		"vite": "^7.0.0",
		"vitest": "^3.2.4"
	}
}
